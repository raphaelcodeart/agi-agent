# ==============================================================================
# Multi-Tenant Social Publishing Platform - Environment Configuration Example
# Copy this file to .env and configure the variables.
# Do not commit real production secrets to git.
# ==============================================================================

# System environment
ENVIRONMENT=local # local, staging, production

# JWT & Authentication Secret Keys
# Generate using: openssl rand -hex 32
SECRET_KEY=supersecretjwtkeyforadminauthsocialpublisher123!

# Token Encryption Key
# Must be a 32-byte URL-safe base64-encoded string.
# Generate in Python using: cryptography.fernet.Fernet.generate_key().decode()
ENCRYPTION_KEY=38x26P_s-Ld_j4pL9V10L1-82h0YF6p2-LpE10d9Y2I=

# Database Settings
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass_123
POSTGRES_DB=social_publisher
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres_secure_pass_123@db:5432/social_publisher

# Redis & Background Workers
REDIS_URL=redis://redis:6379/0

# Buffer API Integration Details
# Set to 'mock' to run the platform locally using the Mock Buffer Adapter.
# In 'production', each user connects by pasting their own personal Buffer API
# key in the dashboard (Buffer has no working third-party OAuth as of July
# 2026) - there is no platform-level client id/secret to configure here.
BUFFER_INTEGRATION_MODE=mock

# Media Storage Settings
# Max upload size: 100MB (104857600 bytes)
UPLOAD_MAX_SIZE_BYTES=104857600
MEDIA_STORAGE_DIR=/storage/uploads
THUMBNAIL_STORAGE_DIR=/storage/thumbnails
# Public origin of the "media" nginx vhost (see infrastructure/nginx/nginx.conf).
# Must be a real public HTTPS origin in production - Buffer fetches post media by
# URL and refuses non-HTTPS links. See docs/DEPLOYMENT.md section 9 (scripts/setup-https.sh).
PUBLIC_MEDIA_BASE_URL=http://localhost:8080
TEMPORARY_STORAGE_DIR=/storage/temporary

# Concurrency & Retries Settings
GLOBAL_CONCURRENCY_LIMIT=5
CONCURRENT_JOBS_PER_CONNECTION=1
PAUSE_BETWEEN_REQUESTS_SECONDS=10
MAX_PUBLICATION_ATTEMPTS=5
RETRY_BACKOFF_SEQUENCE_SECONDS=60,300,900,3600,21600

# Next.js Public APIs Config (Dashboard container will use these)
# Origin the BROWSER uses to reach the backend directly (rarely needed: almost all
# dashboard API calls go through its same-origin BFF proxy, never exposing the admin
# JWT to client-side JavaScript).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side origin the dashboard container uses to reach the api container directly
# (Docker service name). Falls back to NEXT_PUBLIC_API_URL when unset.
API_INTERNAL_URL=http://api:8000

# Enables the dashboard's mock data adapter for offline/local UI development.
# Must never be "true" in production; the dashboard build ignores this flag when
# NODE_ENV=production regardless of the value set here.
NEXT_PUBLIC_USE_MOCK_API=false
