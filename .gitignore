# Secrets - never commit real environment files
.env
.env.local
.env.*.local
apps/api/.env
apps/dashboard/.env.local

# Node / pnpm
node_modules/
.pnpm-store/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Database backups (contain real data - keep them off git, download/store separately)
backups/*.sql
!backups/.gitkeep

# Media uploads (bind-mounted volume content, not source)
storage/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log

# Celery beat runtime schedule file
celerybeat-schedule
